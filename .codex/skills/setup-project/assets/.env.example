# .env.example — sao chép thành .env ở GỐC dự án rồi điền 2 giá trị thật.
# KHÔNG commit .env. KHÔNG chia sẻ token cho ai.

# API token Cloudflare (giới hạn quyền — KHÔNG phải Global API Key)
CF_API_TOKEN=dan_token_vao_day

# Cloudflare Account ID (Workers & Pages -> cột bên phải)
CF_ACCOUNT_ID=dan_account_id_vao_day
